{
  "name": "secq-auto-workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 execute secq-auto-db --local --file=./schema.sql",
    "db:remote": "wrangler d1 execute secq-auto-db --remote --file=./schema.sql",
    "db:migrate:local": "wrangler d1 migrations apply secq-auto-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply secq-auto-db --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0",
    "openai": "^4.60.0",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "xlsx": "^0.18.5",
    "pdf-parse": "^1.1.1",
    "csv-parse": "^5.5.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240900.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.78.0",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0"
  }
}